{
  "name": "local-code-agent",
  "version": "0.1.0",
  "description": "Local TypeScript CLI orchestrator using Codex CLI and Claude Code CLI",
  "type": "module",
  "main": "dist/cli/index.js",
  "bin": {
    "orchestrator": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "node --experimental-vm-modules node_modules/.bin/jest"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "execa": "^9.0.0",
    "pino": "^9.0.0",
    "simple-git": "^3.24.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "eslint": "^8.57.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "jest": "^29.0.0",
    "@types/jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0"
  }
}
